<script>
async function loadAllData() {
    try {
        // 1. 현재가 데이터 로드
        const pricesUrl = 'https://raw.githubusercontent.com/cison2023/ETF-1/main/prices.json';
        const pricesResponse = await fetch(pricesUrl);
        const pricesData = await pricesResponse.json();
        
        // 2. 분배금 데이터 로드
        const distUrl = 'https://raw.githubusercontent.com/cison2023/ETF-1/main/distributions.json';
        const distResponse = await fetch(distUrl);
        const distributionData = await distResponse.json();
        
        // 3. 데이터 병합
        const queryDate = document.getElementById('queryDate').value;
        const pricesByDate = pricesData[queryDate] || {};
        
        etfDataList.forEach(etf => {
            // 현재가 업데이트
            if (pricesByDate[etf.code]) {
                etf.price = pricesByDate[etf.code].today;
            }
            
            // 분배금 데이터 업데이트
            if (distributionData[etf.code]) {
                const distInfo = distributionData[etf.code];
                etf.name = distInfo.name;
                etf.divBaseDate = distInfo.divBaseDate;
                etf.exDivDate = distInfo.exDivDate;
                etf.distribution = distInfo.data;
                etf.isLoaded = true;
            }
        });
        
        saveData();
        renderTable();
        showAlert('✅ 모든 데이터가 GitHub에서 로드되었습니다!', 'success');
    } catch (error) {
        showAlert(`❌ 데이터 로드 실패: ${error.message}`, 'error');
    }
}
</script>
